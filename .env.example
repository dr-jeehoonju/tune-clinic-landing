# =====================================================
# Tune Clinic — Environment Variables (template)
# =====================================================
# Copy this file to `.env` (gitignored) and fill in real values.
# Build-time only: these are used by Eleventy / Sharp / Gemini scripts.
# =====================================================

# Gemini (used by scripts/gemini-*.js for blog automation, optional)
GEMINI_API_KEY=

# =====================================================
# Supabase Edge Function secrets (NOT loaded from .env)
# Set these via the Supabase CLI:
#
#   supabase secrets set RESEND_API_KEY=re_xxx
#   supabase secrets set FROM_EMAIL='Tune Clinic <booking@tuneclinic-global.com>'
#   supabase secrets set CLINIC_NOTIFICATION_EMAIL='clinic@example.com,owner@example.com'
#   supabase secrets set BOOKING_HMAC_SECRET=$(openssl rand -hex 32)
#
# Phase 5 — Cloudflare Turnstile (anti-bot CAPTCHA on the booking form):
#   supabase secrets set TURNSTILE_SECRET_KEY=0xAA...               # production
#   supabase secrets set TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA  # always-pass test key
#
# The matching sitekey lives in src/fragments/*/booking.html (rendered into
# the public HTML). For production, replace the demo sitekey
# `1x00000000000000000000AA` in those fragments with your real one and
# rebuild.
#
# Verify with:  supabase secrets list
# =====================================================
