{
  "name": "tune-clinic-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i src/styles/site.css -o dist/css/site.css --minify",
    "build:static": "node scripts/copy-static.js",
    "build:eleventy": "eleventy",
    "build": "npm run build:css && npm run build:static && npm run build:eleventy",
    "dev:css": "tailwindcss -i src/styles/site.css -o dist/css/site.css --watch",
    "dev:static": "node scripts/copy-static.js",
    "dev:eleventy": "eleventy --serve",
    "dev": "npm run dev:static && run-p dev:css dev:eleventy",
    "start": "npm run dev",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2"
  },
  "devDependencies": {
    "@google/genai": "^1.49.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0"
  }
}
